{
    "version": 2,
    "functions": {
        "api/index.js": {
            "runtime": "@vercel/node@2.0.0",
            "maxDuration": 10,
            "memory": 1024
        }
    },
    "routes": [
        { "src": "/api/(.*)", "dest": "/api/index.js"},
        {"src":"/","dest":"/api/index.js"}
    ]   
}